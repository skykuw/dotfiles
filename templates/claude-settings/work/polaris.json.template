{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "sonnet",
  "alwaysThinkingEnabled": false,
  "effortLevel": "medium",
  "showThinkingSummaries": false,
  "tui": "fullscreen",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Task",
      "ExitPlanMode(*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "Bash(basename *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(file *)",
      "Bash(ls *)",
      "Bash(md5 *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(shasum *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(date *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(hostname *)",
      "Bash(id *)",
      "Bash(ps *)",
      "Bash(pwd *)",
      "Bash(uname *)",
      "Bash(whoami *)",
      "Bash(cut *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(git *)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(python --version)",
      "Bash(ruby --version)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(dd *)",
      "Bash(diskutil *)",
      "Bash(mkfs *)",
      "Bash(rm -rf / *)",
      "Bash(rm -rf /* *)",
      "Bash(rm -rf ~ *)",
      "Bash(rm -rf $HOME *)",
      "Bash(sudo rm -rf / *)",
      "Bash(sudo rm -rf /* *)",
      "Bash(npm publish *)",
      "Bash(yarn publish *)",
      "Bash(pnpm publish *)",
      "Bash(cargo publish *)",
      "Bash(gem push *)",
      "Bash(twine upload *)",
      "Bash(python -m twine upload *)",
      "Bash(docker push *)",
      "Bash(gh gist *)",
      "Bash(gh repo create *)",
      "Bash(gh release create *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh work/polaris",
    "refreshInterval": 5
  },
  "env": {
    "CLAUDE_STATUSLINE_RATELIMITS": "off"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/notify.sh idle_prompt",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/notify.sh permission_prompt",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
