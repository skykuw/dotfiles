{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "opus",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showThinkingSummaries": true,
  "tui": "fullscreen",
  "cleanupPeriodDays": 90,
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": ["~/.claude/"],
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Task",
      "ExitPlanMode(*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "Bash(basename *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(file *)",
      "Bash(ls *)",
      "Bash(md5 *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(shasum *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(date *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(hostname *)",
      "Bash(id *)",
      "Bash(ps *)",
      "Bash(pwd *)",
      "Bash(uname *)",
      "Bash(whoami *)",
      "Bash(cut *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(python --version)",
      "Bash(ruby --version)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(dd *)",
      "Bash(diskutil *)",
      "Bash(mkfs *)",
      "Bash(rm -rf / *)",
      "Bash(rm -rf /* *)",
      "Bash(rm -rf ~ *)",
      "Bash(rm -rf $HOME *)",
      "Bash(sudo rm -rf / *)",
      "Bash(sudo rm -rf /* *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh pr merge *)",
      "Bash(npm publish *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh personal",
    "refreshInterval": 5
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus"
  }
}
