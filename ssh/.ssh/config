# ~/.ssh/config — universal SSH config (tracked in dotfiles).
# Host-specific entries (IdentityFile paths, internal hostnames, ProxyJump
# targets) live in ~/.ssh/config.local — NOT tracked. Include order matters:
# the FIRST matching value wins in ssh_config, so include local first to let
# it override anything below.

Include ~/.ssh/config.local

# Common defaults applied to all hosts (overridable by config.local since
# Include comes before).
Host *
	ServerAliveInterval 60
	ServerAliveCountMax 3
	AddKeysToAgent yes
	UseKeychain yes
