# macOS / editors / VCS junk
.DS_Store
Brewfile.lock.json
*.swp
*.swo
*~
.idea/
.vscode/

# Local-only overrides — keep these out of the repo
*.local
.env
.env.*
!.env.example

# The `bin` stow package uses a `.local/bin/` subtree so stow lands scripts in
# ~/.local/bin/. That directory name collides with the *.local rule above —
# re-include it (and its contents) explicitly.
!bin/.local
!bin/.local/**

# Claude Code settings are machine-specific, seeded from templates/claude-settings/
# on bootstrap. Never commit — the profile (personal vs work/<codename>) is private
# per-machine state.
claude/.claude/settings.json
