#!/usr/bin/env bash
# Pre-commit hook: per-file-kind lint for staged changes.
#
# Dispatches by extension *and* by shebang so a PATH script without a `.sh`
# suffix (like bin/.local/bin/extract) still gets shellchecked. Checks the
# working-tree content of staged files — if you partially staged a file and
# left broken bits unstaged, fix and re-stage before retrying.
#
# Bypass for emergencies:  git commit --no-verify
#
# Missing tools are reported once and skipped, not fatal, so a freshly-cloned
# machine can still commit before `brew bundle` has run.

set -uo pipefail

RED=$'\033[1;31m'; YELLOW=$'\033[1;33m'; DIM=$'\033[2m'; RESET=$'\033[0m'

fail=0
missing_tools=" "   # space-delimited sentinel so `set -u` is happy with 3.2

report_missing() {
  local tool="$1"
  [[ "$missing_tools" == *" $tool "* ]] && return 0
  missing_tools="$missing_tools$tool "
  printf '%swarn%s  %s not installed — skipping %s checks (install via Brewfile)\n' \
    "$YELLOW" "$RESET" "$tool" "$tool" >&2
}

have() { command -v "$1" >/dev/null 2>&1; }

is_shell() {
  # By extension
  case "$1" in *.sh|*.bash) return 0 ;; esac
  # By shebang (binary-safe: read only first line)
  local first
  first=$(head -n 1 "$1" 2>/dev/null || true)
  [[ "$first" =~ ^#!.*/(env[[:space:]]+)?(ba)?sh([[:space:]]|$) ]]
}

is_json() {
  case "$1" in
    */lazy-lock.json) return 1 ;;   # auto-generated by nvim, don't lint
    *.json|*.json.template) return 0 ;;
    *) return 1 ;;
  esac
}

is_zsh() {
  case "$1" in
    zsh/.zshrc|zsh/.zprofile|*.zsh) return 0 ;;
    *) return 1 ;;
  esac
}

check_shell() {
  local f="$1"
  if ! bash -n "$f" 2>/tmp/.pc_err; then
    printf '%sfail%s  %s: bash -n\n%s%s%s\n' "$RED" "$RESET" "$f" "$DIM" "$(cat /tmp/.pc_err)" "$RESET"
    fail=1
    return
  fi
  if have shellcheck; then
    # Default severity (info) — catches SC2086 (unquoted vars) and SC2295
    # (unquoted pattern in parameter expansion), both of which have bitten us.
    if ! shellcheck "$f" 2>/tmp/.pc_err; then
      printf '%sfail%s  %s: shellcheck\n%s\n' "$RED" "$RESET" "$f" "$(cat /tmp/.pc_err)"
      fail=1
    fi
  else
    report_missing shellcheck
  fi
}

check_json() {
  local f="$1"
  if have jq; then
    if ! jq empty "$f" 2>/tmp/.pc_err; then
      printf '%sfail%s  %s: jq empty\n%s%s%s\n' "$RED" "$RESET" "$f" "$DIM" "$(cat /tmp/.pc_err)" "$RESET"
      fail=1
    fi
  else
    report_missing jq
  fi
}

check_zsh() {
  local f="$1"
  if have zsh; then
    if ! zsh -n "$f" 2>/tmp/.pc_err; then
      printf '%sfail%s  %s: zsh -n\n%s%s%s\n' "$RED" "$RESET" "$f" "$DIM" "$(cat /tmp/.pc_err)" "$RESET"
      fail=1
    fi
  else
    report_missing zsh
  fi
}

# --diff-filter=ACMR: added / copied / modified / renamed. Skip deletions.
# Portable read loop — macOS ships bash 3.2, which has no mapfile.
while IFS= read -r f; do
  [[ -f "$f" ]] || continue
  if   is_shell "$f"; then check_shell "$f"
  elif is_json  "$f"; then check_json  "$f"
  elif is_zsh   "$f"; then check_zsh   "$f"
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR)

rm -f /tmp/.pc_err
exit "$fail"
