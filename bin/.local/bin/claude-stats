#!/usr/bin/env bash
# claude-stats — per-day / per-project token-usage summary over Claude Code
# session transcripts.
#
# Aggregates input / cache-read / cache-write / output tokens across every
# assistant turn in ~/.claude/projects/*/*.jsonl (subagent sidechains
# excluded). Cost is an estimate from a hardcoded price table (see PRICES
# below — update when Anthropic's public rates change). Durations use
# first-to-last timestamp per transcript.
#
# Usage:
#   claude-stats                       # by day, last 14 days
#   claude-stats --by project          # group by project instead
#   claude-stats --since 2026-04-01    # custom cutoff date
#   claude-stats --since 7d            # shorthand: last 7 days
#   claude-stats --no-cost             # suppress cost column
#
# Deps: jq, awk. No fzf.

set -uo pipefail

PROJECTS_DIR="$HOME/.claude/projects"
[[ -d "$PROJECTS_DIR" ]] || { echo "No $PROJECTS_DIR" >&2; exit 1; }
command -v jq   >/dev/null 2>&1 || { echo "jq not installed"   >&2; exit 1; }
command -v awk  >/dev/null 2>&1 || { echo "awk not installed"  >&2; exit 1; }

GROUP_BY="day"           # day | project
SINCE_SPEC="14d"         # NNNd or YYYY-MM-DD
SHOW_COST=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --by)        GROUP_BY="$2"; shift 2 ;;
    --since)     SINCE_SPEC="$2"; shift 2 ;;
    --no-cost)   SHOW_COST=0; shift ;;
    -h|--help)   sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *)           echo "unknown arg: $1 (try --help)" >&2; exit 2 ;;
  esac
done

case "$GROUP_BY" in day|project) ;; *) echo "--by must be day or project" >&2; exit 2 ;; esac

# Resolve SINCE_SPEC to a Unix epoch (start of day).
if [[ "$SINCE_SPEC" =~ ^([0-9]+)d$ ]]; then
  days="${BASH_REMATCH[1]}"
  SINCE_EPOCH=$(date -u -v-"${days}"d "+%s" 2>/dev/null || date -u -d "-$days days" "+%s")
elif [[ "$SINCE_SPEC" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
  SINCE_EPOCH=$(date -u -j -f "%Y-%m-%d" "$SINCE_SPEC" "+%s" 2>/dev/null \
             || date -u -d "$SINCE_SPEC" "+%s")
else
  echo "--since must be NNNd or YYYY-MM-DD" >&2; exit 2
fi

# --- Pricing table (USD per million tokens) --------------------------------
# Update when Anthropic's public rates change. Keys match a substring of the
# .message.model string as reported in transcripts (e.g. "claude-opus-4-7").
# Unknown models fall through to the "default" row.
# input → base input. cache_write_5m → 1.25×. cache_write_1h → 2×.
# cache_read → 0.1× input. Output priced separately.
price_for_model() {
  case "$1" in
    *opus*)    echo "15.00 75.00" ;;   # input  output
    *sonnet*)  echo  "3.00 15.00" ;;
    *haiku*)   echo  "0.80  4.00" ;;
    *)         echo  "3.00 15.00" ;;   # default → sonnet-class
  esac
}

# --- Walk transcripts and emit per-session aggregate rows ------------------
# Row format (unit-sep delimited):
#   <date_ymd>  <project>  <input>  <cache_write_5m>  <cache_write_1h>  <cache_read>  <output>  <dur_s>  <model>
emit_rows() {
  find "$PROJECTS_DIR" -maxdepth 2 -name '*.jsonl' 2>/dev/null | while IFS= read -r f; do
    mtime=$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)
    (( mtime < SINCE_EPOCH )) && continue

    cwd=$(jq -r 'select(.cwd) | .cwd' "$f" 2>/dev/null | head -1)
    project="${cwd##*/}"
    [[ -z "$project" ]] && project=$(basename "$(dirname "$f")")

    date_ymd=$(date -r "$mtime" "+%Y-%m-%d" 2>/dev/null || date -d "@$mtime" "+%Y-%m-%d")

    # Single jq pass: sum assistant token fields, capture first/last timestamp
    # (as epoch ms via strptime would need jq 1.6+; we'll get the raw ISO and
    # convert in awk). Also emit the model (last assistant model wins).
    jq -r --arg proj "$project" --arg day "$date_ymd" '
      def iso2epoch: if . == null or . == "" then 0
                     else (split(".")[0] | sub("Z$"; "") + "Z" | fromdateiso8601 // 0) end;
      [ inputs ]
      | map(select(.type == "assistant")) as $asst
      | ($asst | map(.message.usage.input_tokens // 0) | add // 0) as $in
      | ($asst | map(.message.usage.cache_creation.ephemeral_5m_input_tokens // 0) | add // 0) as $cw5
      | ($asst | map(.message.usage.cache_creation.ephemeral_1h_input_tokens // 0) | add // 0) as $cw1
      | ($asst | map(.message.usage.cache_read_input_tokens // 0) | add // 0) as $cr
      | ($asst | map(.message.usage.output_tokens // 0) | add // 0) as $out
      | ($asst | map(.timestamp) | map(select(. != null))) as $ts
      | (($ts | first // "") | iso2epoch) as $ef
      | (($ts | last  // "") | iso2epoch) as $el
      | (if $el > $ef then $el - $ef else 0 end) as $dur
      | ($asst | map(.message.model) | last // "unknown") as $model
      | [$day, $proj, $in, $cw5, $cw1, $cr, $out, $dur, $model]
      | join("")
    ' <"$f" 2>/dev/null
  done
}

# --- Aggregate + render ----------------------------------------------------
emit_rows | awk -F $'\x1f' -v group="$GROUP_BY" -v show_cost="$SHOW_COST" '
  function price_in(model) {
    if (model ~ /opus/)   return 15.0
    if (model ~ /haiku/)  return 0.80
    return 3.0
  }
  function price_out(model) {
    if (model ~ /opus/)   return 75.0
    if (model ~ /haiku/)  return 4.0
    return 15.0
  }
  {
    day=$1; proj=$2;
    in_t=$3+0; cw5=$4+0; cw1=$5+0; cr=$6+0; out=$7+0;
    dur=$8+0; model=$9
    key = (group == "day") ? day : proj
    sessions[key]++
    sum_in[key]   += in_t
    sum_cw5[key]  += cw5
    sum_cw1[key]  += cw1
    sum_cr[key]   += cr
    sum_out[key]  += out
    pi = price_in(model); po = price_out(model)
    cost[key] += (in_t + cw5 * 1.25 + cw1 * 2.0 + cr * 0.1) / 1e6 * pi \
               + out / 1e6 * po
    sum_dur[key] += dur
  }
  END {
    # column labels
    if (show_cost)
      printf "%-12s  %8s  %10s  %10s  %10s  %10s  %8s  %9s\n", \
        (group == "day" ? "date" : "project"), "sessions", "input", "cache_wr", "cache_rd", "output", "duration", "cost(~$)"
    else
      printf "%-12s  %8s  %10s  %10s  %10s  %10s  %8s\n", \
        (group == "day" ? "date" : "project"), "sessions", "input", "cache_wr", "cache_rd", "output", "duration"

    # sort keys: days descending, projects alphabetical
    n = 0
    for (k in sessions) keys[n++] = k
    if (group == "day") {
      # insertion sort desc by string (ISO date sorts lexically)
      for (i = 1; i < n; i++) for (j = i; j > 0 && keys[j] > keys[j-1]; j--) { t=keys[j]; keys[j]=keys[j-1]; keys[j-1]=t }
    } else {
      for (i = 1; i < n; i++) for (j = i; j > 0 && keys[j] < keys[j-1]; j--) { t=keys[j]; keys[j]=keys[j-1]; keys[j-1]=t }
    }

    tot_s=0; tot_in=0; tot_cw=0; tot_cr=0; tot_out=0; tot_dur=0; tot_cost=0
    for (i = 0; i < n; i++) {
      k = keys[i]
      cw = sum_cw5[k] + sum_cw1[k]
      dur_h = int(sum_dur[k] / 3600); dur_m = int((sum_dur[k] % 3600) / 60)
      dur_s = sprintf("%dh%02dm", dur_h, dur_m)
      if (show_cost)
        printf "%-12s  %8d  %10s  %10s  %10s  %10s  %8s  %9.2f\n", \
          k, sessions[k], hum(sum_in[k]), hum(cw), hum(sum_cr[k]), hum(sum_out[k]), dur_s, cost[k]
      else
        printf "%-12s  %8d  %10s  %10s  %10s  %10s  %8s\n", \
          k, sessions[k], hum(sum_in[k]), hum(cw), hum(sum_cr[k]), hum(sum_out[k]), dur_s
      tot_s += sessions[k]; tot_in += sum_in[k]; tot_cw += cw
      tot_cr += sum_cr[k]; tot_out += sum_out[k]; tot_dur += sum_dur[k]
      tot_cost += cost[k]
    }
    dur_h = int(tot_dur / 3600); dur_m = int((tot_dur % 3600) / 60)
    dur_s = sprintf("%dh%02dm", dur_h, dur_m)
    if (show_cost)
      printf "%-12s  %8d  %10s  %10s  %10s  %10s  %8s  %9.2f\n", \
        "total", tot_s, hum(tot_in), hum(tot_cw), hum(tot_cr), hum(tot_out), dur_s, tot_cost
    else
      printf "%-12s  %8d  %10s  %10s  %10s  %10s  %8s\n", \
        "total", tot_s, hum(tot_in), hum(tot_cw), hum(tot_cr), hum(tot_out), dur_s
  }
  function hum(n) {
    if (n >= 1e9)  return sprintf("%.2fG", n/1e9)
    if (n >= 1e6)  return sprintf("%.2fM", n/1e6)
    if (n >= 1e3)  return sprintf("%.1fk", n/1e3)
    return sprintf("%d", n)
  }
'
